generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  email        String   @unique
  password     String
  isAdmin      Boolean  @default(false)
  selectedRole String?  @map("selected_role")
  customerId   String?  @map("customer_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies     Company[]
  roles         Role[]
  members       Member[]
  notifications Notification[]

  @@map("users")
}

model VerificationCodes {
  id        String   @id @default(uuid())
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  email     String   @unique
  otp       String
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("verification_codes")
}

model RestoreCodes {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("restore_codes")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  isBlocked Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author   User   @relation(fields: [authorId], references: [id])
  authorId String @map("author_id")

  plan   Plan?   @relation(fields: [planId], references: [id]) // The company's chosen plan
  planId String? @map("plan_id")

  currentSubscriptionId String? @map("current_subscription_id")

  subscriptions CompanySubscription[] @relation("companySubscriptions") // All subscriptions

  roles             Role[]
  members           Member[]
  sentNotifications Notification[]
  workspaces        Workspace[]
  sheets            Sheet[]
  selects           Select[]
  columns           Column[]
  tasks             Task[]

  @@map("companies")
}

model CompanySubscription {
  id            String   @id @default(uuid())
  startDate     DateTime @map("start_date")
  endDate       DateTime @map("end_date")
  dueDate       Int      @default(30)
  requestsCount Int      @default(0)
  isExpired     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plan   Plan   @relation(fields: [planId], references: [id])
  planId String

  company   Company @relation("companySubscriptions", fields: [companyId], references: [id])
  companyId String  @map("company_id")

  @@map("company_subscriptions")
}

model Role {
  id        String    @id @default(uuid())
  type      RoleTypes
  createdAt DateTime  @default(now()) @map("created_at")

  company   Company @relation(fields: [companyId], references: [id])
  companyId String  @map("company_id")
  user      User    @relation(fields: [userId], references: [id])
  userId    String  @map("user_id")
  access    Member? @relation(fields: [memberId], references: [id])
  memberId  String? @unique @map("member_id")

  @@map("roles")
}

enum RoleTypes {
  AUTHOR
  MEMBER
  VIEWER
}

model Member {
  id             String              @id @default(uuid())
  type           MemberTypes
  permissions    MemberPermissions[]
  view           ViewType
  status         MemberStatus        @default(NEW)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  company        Company             @relation(fields: [companyId], references: [id])
  companyId      String              @map("company_id")
  user           User                @relation(fields: [userId], references: [id])
  userId         String              @map("user_id")
  role           Role?
  notification   Notification?       @relation(fields: [notificationId], references: [id])
  notificationId String?             @unique @map("notification_id")
  workspaces     Workspace[]         @relation("MemberWorkspaces")
  Task           Task?               @relation(fields: [taskId], references: [id])
  taskId         String?

  @@map("members")
}

enum MemberTypes {
  MEMBER
  VIEWER
}

enum MemberPermissions {
  ALL
  READ
  CREATE
  UPDATE
  DELETE
}

enum ViewType {
  ALL
  OWN
}

enum MemberStatus {
  NEW
  ACTIVE
  REJECTED
  CANCELLED
}

model Notification {
  id          String           @id @default(uuid())
  isRead      Boolean          @default(false)
  type        NotificationType
  text        String
  from        NotificationFrom
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  fromCompany Company?         @relation(fields: [companyId], references: [id])
  companyId   String?          @map("company_id")
  toUser      User             @relation(fields: [userId], references: [id])
  userId      String           @map("user_id")
  member      Member?

  @@map("notifications")
}

enum NotificationFrom {
  APPLICATION_TEAM
  COMPANY
}

enum NotificationType {
  NOTIFICATION
  INVITATION
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  order     Int      @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String   @map("company_id")
  sheets    Sheet[]
  members   Member[] @relation("MemberWorkspaces")
  tasks     Task[]

  @@map("workspaces")
}

model Sheet {
  id          String    @id @default(uuid())
  name        String
  order       Int       @default(autoincrement())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String    @map("workspace_id")
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String    @map("company_id")
  columns     Column[]
  tasks       Task[]

  @@map("sheets")
}

model Plan {
  id                   String                @id @default(uuid())
  name                 String
  description          String?
  price                Int
  maxWorkspaces        Int                   @map("max_workspaces")
  maxSheets            Int                   @map("max_sheets")
  maxMembers           Int                   @map("max_members")
  maxViewers           Int                   @map("max_viewers")
  order                Int                   @default(autoincrement())
  companies            Company[]
  companySubscriptions CompanySubscription[]

  @@map("plans")
}

model Select {
  id        String   @id @default(uuid())
  title     String   @default("untitled")
  color     String
  options   Option[]
  company   Company  @relation(fields: [companyId], references: [id])
  companyId String   @map("company_id")

  @@map("selects")
}

model Option {
  id       String @id @default(uuid())
  name     String
  select   Select @relation(fields: [selectId], references: [id])
  selectId String @map("select_id")

  @@map("options")
}

model Column {
  id        String     @id @default(uuid())
  name      String
  key       String
  show      Boolean    @default(true)
  type      ColumnType
  company   Company    @relation(fields: [companyId], references: [id])
  companyId String     @map("company_id")
  sheet     Sheet      @relation(fields: [sheetId], references: [id])
  sheetId   String     @map("sheet_id")

  @@map("columns")
}

enum ColumnType {
  SELECT
  TEXT
  NUMBER
  LINK
  MEMBER
  DATE
  DUEDATE
  FILE
  CHECK
}

model Task {
  id       String   @id @default(uuid())
  status   String?
  priority String?
  link     String?
  price    Int?
  paid     Boolean?

  text1       String?
  text2       String?
  text3       String?
  text4       String?
  text5       String?
  number1     String?
  number2     String?
  number3     String?
  number4     String?
  number5     String?
  checkbox1   Boolean?
  checkbox2   Boolean?
  checkbox3   Boolean?
  checkbox4   Boolean?
  checkbox5   Boolean?
  select1     String?
  select2     String?
  select3     String?
  select4     String?
  select5     String?
  date1       DateTime?
  date2       DateTime?
  date3       DateTime?
  date4       DateTime?
  date5       DateTime?
  members     Member[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String    @map("workspace_id")
  sheet       Sheet     @relation(fields: [sheetId], references: [id])
  sheetId     String    @map("sheet_id")
  company     Company   @relation(fields: [companyId], references: [id])
  companyId   String    @map("company_id")

  @@map("tasks")
}
